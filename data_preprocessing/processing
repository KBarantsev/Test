#Загрузка файлов Microsoft Access Table Shortcut (mat)
import scipy.io
mat_train = scipy.io.loadmat('/content/wider_face_split/wider_face_train.mat')
mat_val = scipy.io.loadmat('/content/wider_face_split/wider_face_val.mat')
mat_test = scipy.io.loadmat('/content/wider_face_split/wider_face_test.mat')

#функция, формирующая список словарей с названиями файлов картинок, размерами картинок и координатами боксов (x,y, h,w)
import scipy.io
import skimage.io

def load_annotations(mat, mode):

  
  num_events = len(mat.get('file_list'))
  data_infos = []

  for event in range(num_events): #цикл по папкам тематик картинок

      num_images_in_folder = len(mat.get('file_list')[event][0])
      prefix = mat.get('event_list')[event][0][0]

      for i in range(num_images_in_folder): #цикл по картинкам внутри папки
          image_name = mat.get('file_list')[event][0][i][0][0]
          image_id=f'{prefix}/{image_name}.jpg'

          way_to_img = f'/content/WIDER_{mode}/images/{image_id}'
          image = skimage.io.imread(way_to_img)
          height, width = image.shape[:2]
          data_info = dict(filename=f'{image_id}', width=width, height=height)

          if mode != 'test':
              bboxes = mat.get('face_bbx_list')[event][0][i][0]
              data_anno = dict(bboxes=bboxes)
              data_info.update(ann=data_anno)

          data_infos.append(data_info)

  return data_infos


#формирование списков словарей с названиями файлов картинок, размерами картинок и координатами боксов (x,y, h,w)
data_train = load_annotations(mat_train,'train')
data_val = load_annotations(mat_val,'val')
data_test = load_annotations(mat_test,'test')

#формирование соответствующих датафреймов
import pandas as pd
data_train_pd = pd.DataFrame(data_train)
data_val_pd = pd.DataFrame(data_val)
data_test_pd = pd.DataFrame(data_test)

#количество картинок в train, val, test
print(len(data_train_pd), len(data_val_pd), len(data_test_pd))

#поиск картинок, у которых нет боксов. Выведем их индексы
indexes_bad_images_train = [i for i in range(len(data_train_pd)) if (data_train_pd['ann'][i]['bboxes'].sum() == 0)]
indexes_bad_images_val = [i for i in range(len(data_val_pd)) if (data_val_pd['ann'][i]['bboxes'].sum() == 0)]
print(indexes_bad_images_train)
print(indexes_bad_images_val)

#удаляем строки без боксов
data_train_pd = data_train_pd.drop(index = indexes_bad_images_train) 
data_val_pd = data_val_pd.drop(index = indexes_bad_images_val)

#новая индексация с учетем удаленных строк
data_train_pd.index = list(range(len(data_train_pd))) 
data_val_pd.index = list(range(len(data_val_pd)))


