#функция сглаживания. Каждая точка списка на выходе является средним от points соседних точек списка на входе.
import numpy as np
def smooth(list1,points):
    ker = np.ones(points)
    lenght = len(ker)
    list2=[]
    for i in range(len(list1)-lenght+1):
        fragm = np.array(list1[i:i+lenght])
        x = fragm.dot(ker)/lenght
        list2.append(x)
    return list2  

#функция n-кратного применения сглаживания
def n_smooth(list1,smooth,points,n):
    for n in range(n):
        list1 = smooth(list1,points)
    return list1  


