#функция вычисления метрик Precision, Recall, F1 для одной картинки
def metrics(boxes_Gr, boxes_Pr,tr):
    if (len(boxes_Pr)!=0)&(len(boxes_Gr)!=0):
        IoU_tensor = torchvision.ops.box_iou(boxes_Gr, boxes_Pr) #матрица IoU между предсказаными и truth боксами
        IoU_tensor = IoU_tensor.cpu()
        TP = (IoU_tensor>tr).sum().item() #число true positive боксов по порогу tr
        if TP != 0.:
            FP = ((IoU_tensor>tr).sum(0) == 0).sum().item() #число false positive боксов
            FN = ((IoU_tensor>tr).sum(1) == 0).sum().item() #число false negative боксов
            Recall = np.float16(TP/(TP+FN))
            Precision = np.float16(TP/(TP+FP))
            F1 = np.float16(2*(Precision*Recall)/(Precision + Recall))
            return Precision, Recall, F1
        else:
            return 0,0,0   
    else:
        return 0,0,0

