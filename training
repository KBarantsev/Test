#функция, которая преобразует батч боксов (тензор) в список словарей для подачи на вход модели. 
#Из тензора удаляются нулевые строки и боксы, не удовлетворяющие x2>x1 и y2>y1.
def prepare_labels(labels,batch_size):
    label_list = []
    for j in range(batch_size):
        x = labels[j][labels[j].sum(1)!=0]
        delta_x = (x[:,2]-x[:,0])>0.
        delta_y = (x[:,3]-x[:,1])>0.
        delta_xy = delta_x*delta_y
        x = x[delta_xy]
        label_dict = {'boxes': x.to(torch.float), 
                      'labels': (torch.IntTensor(len(x)).zero_().to(torch.int64)+1).to(device)}
        label_list.append(label_dict)

    return label_list

