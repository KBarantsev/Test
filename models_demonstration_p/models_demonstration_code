#загрузим словарь соответствия меток классов их названиям в COCO датасете
utils = torch.hub.load('NVIDIA/DeepLearningExamples:torchhub', 'nvidia_ssd_processing_utils')
classes_to_labels = utils.get_coco_object_dictionary()

#загрузим в файловую директорию несколько произвольных картинок, создадим список путей к файлам (скопировав путь к ним)
uris = [
    '/content/150101870_0_139_600_479_600x0_80_0_0_ef590b1c50422a55f3b34edd72c47e26.jpg',
    '/content/mos700.jpg',
    '/content/photo-goroda-kanadi-2-731x488.jpg'
]

#функция, которая по названию файла возвращает torch тензор нужной размерности
import cv2
def image_to_tensor(uri):
    img=cv2.imread(uri)[:,:,::-1]
    img=img.copy()
    img=torch.from_numpy(img)
    img = torch.permute(img, (2, 0, 1))
    img=img[None,:,:,:]
    return img

#forward модели, постобработка, вывод результата
from torchvision.utils import draw_bounding_boxes
from matplotlib import pyplot as plt
model.eval()
treshold=0.3 #порог уверенности бокса

for i in range(len(uris)):
    img = image_to_tensor(uris[i])
    img1 = img/255
    img1=img1.to(device)
    with torch.no_grad():
        detections = model(img1)

    #отсечение по уверенности боксов
    detections[0]['boxes'] = detections[0]['boxes'][detections[0]['scores'] > treshold]
    detections[0]['labels'] = detections[0]['labels'][detections[0]['scores'] > treshold]
    detections[0]['scores'] = detections[0]['scores'][detections[0]['scores'] > treshold] 

    #non max supression (отсечение пересекающихся боксов)

    nms_indexes = torchvision.ops.nms(detections[0]['boxes'], detections[0]['scores'], iou_threshold=0.3)

    detections[0]['boxes'] = detections[0]['boxes'][nms_indexes]
    detections[0]['labels'] = detections[0]['labels'][nms_indexes]
    detections[0]['scores'] = detections[0]['scores'][nms_indexes]


    boxes = detections[0]['boxes']

    labels = detections[0]['labels']
    labels = labels.cpu()
    labels=labels.numpy()
    labels=list(labels)
    labels = [classes_to_labels[i-1] for i in labels]
    
    result = draw_bounding_boxes(img[0], boxes, labels, width=1)
    result = torch.permute(result, (1, 2, 0))
    fig=plt.figure(figsize=(20,30))
    plt.imshow(result)
